# Copy to .env or configure these variables in your process manager.

EEG_ENV=production
EEG_SECRET_KEY=change-this-to-a-long-random-secret
EEG_INITIAL_ADMIN_PASSWORD=change-this-on-first-login
EEG_TIMEZONE=Europe/Vienna

# Optional: only allow requests when a trusted proxy sets CF-IPCountry/X-Country-Code.
# EEG_ALLOWED_COUNTRIES=AT

EEG_HOST=127.0.0.1
EEG_PORT=5000

EEG_ORG_NAME=EEG Portal
EEG_ORG_EMAIL=office@example.org
EEG_ORG_WEBSITE=https://example.org/
EEG_ORG_ADDRESS=Adresse bitte konfigurieren
EEG_ORG_LEGAL=Vereinsdaten bitte konfigurieren

